{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "SQUAD design tokens. Mirror of colors_and_type.css — the CSS is the source of truth; regenerate this when tokens change. W3C DTCG format: $value + $type, aliases in {dot.path}.",

  "color": {
    "$type": "color",
    "terra": {
      "50":  { "$value": "#FDEDE6" }, "100": { "$value": "#FBDDD2" }, "200": { "$value": "#F8B79F" },
      "300": { "$value": "#F26B49", "$description": "Heat Terracotta — accent on dark" },
      "400": { "$value": "#F05633" },
      "500": { "$value": "#EE4721", "$description": "Fired Terracotta — BRAND ANCHOR" },
      "600": { "$value": "#C5371A" }, "700": { "$value": "#9D2C14" }, "800": { "$value": "#75210E" }, "900": { "$value": "#4D1608" }
    },
    "steel": {
      "50":  { "$value": "#F0F2F4" }, "100": { "$value": "#D6DBE0" },
      "200": { "$value": "#BEC4CE", "$description": "Cool Slate" },
      "300": { "$value": "#8E96A1", "$description": "Deep Slate" },
      "400": { "$value": "#6B7480", "$description": "Caption Ash" },
      "500": { "$value": "#3A4550", "$description": "Body Smoke" },
      "600": { "$value": "#1D3444", "$description": "Field Navy" },
      "700": { "$value": "#13222C", "$description": "Jet Ink — BRAND ANCHOR" },
      "800": { "$value": "#0C1820", "$description": "Pressed Jet" },
      "900": { "$value": "#060D14" }
    },
    "linen": {
      "50":  { "$value": "#FAF8F1" },
      "100": { "$value": "#F5F2E9", "$description": "Pressed Bone — the brand white" },
      "200": { "$value": "#EBE7DB", "$description": "Warm Linen — BRAND ANCHOR / page bg" },
      "300": { "$value": "#D8D4CA", "$description": "Hairline" },
      "400": { "$value": "#B5B0A2" }, "500": { "$value": "#8C8775" }, "600": { "$value": "#635E4D" },
      "700": { "$value": "#423F30" }, "800": { "$value": "#28261B" }, "900": { "$value": "#15130A" }
    },
    "success": { "50": { "$value": "#EDF4EE" }, "100": { "$value": "#D3E6D7" }, "200": { "$value": "#ABD0B3" }, "500": { "$value": "#3C8A52", "$description": "Turf Green" }, "600": { "$value": "#2E6E41" }, "700": { "$value": "#1F4E2E" } },
    "warning": { "50": { "$value": "#FAF1DC" }, "100": { "$value": "#F3E1B6" }, "200": { "$value": "#E7CB83" }, "500": { "$value": "#C68A1C", "$description": "Ochre" }, "600": { "$value": "#9C6B12" }, "700": { "$value": "#6E4B0E" } },
    "error":   { "50": { "$value": "#FBEAE9" }, "100": { "$value": "#F6CFCC" }, "200": { "$value": "#EDA8A3" }, "500": { "$value": "#CE2530", "$description": "Signal Red — hue ~25, distinct from terra" }, "600": { "$value": "#A71722" }, "700": { "$value": "#761016" } },
    "info":    { "50": { "$value": "#E9F0F5" }, "100": { "$value": "#C9DDE9" }, "200": { "$value": "#9DBFD4" }, "500": { "$value": "#2C6E9B", "$description": "Slate Blue" }, "600": { "$value": "#205676" }, "700": { "$value": "#163E54" } }
  },

  "sportHue": {
    "$type": "number",
    "$description": "oklch hue per sport. tint chip = oklch(0.95 0.045 H) / oklch(0.56 0.13 H); avatar = oklch(0.90 0.07 H) / oklch(0.40 0.13 H). Identity, never status.",
    "soccer": { "$value": 150 }, "basketball": { "$value": 55 }, "tennis": { "$value": 110 }, "volleyball": { "$value": 255 },
    "padel": { "$value": 195 }, "running": { "$value": 340 }, "gym": { "$value": 290 }, "swimming": { "$value": 220 }
  },

  "theme": {
    "$description": "Role tokens. Components reference ONLY these, never the raw ramps. light = :root, dark = [data-theme=dark].",
    "light": {
      "$type": "color",
      "bgPage": { "$value": "{color.linen.200}" },
      "bgSurface": { "$value": "{color.linen.100}" },
      "bgElevated": { "$value": "{color.linen.50}" },
      "bgInput": { "$value": "{color.linen.50}" },
      "bgTrack": { "$value": "{color.linen.200}" },
      "fgPrimary": { "$value": "{color.steel.700}" },
      "fgBody": { "$value": "{color.steel.500}" },
      "fgCaption": { "$value": "{color.steel.400}" },
      "fgMuted": { "$value": "{color.steel.300}" },
      "ruleHairline": { "$value": "{color.linen.300}" },
      "ruleHairlineStrong": { "$value": "{color.linen.400}" },
      "accent": { "$value": "{color.terra.500}" },
      "accentText": { "$value": "{color.terra.500}" },
      "onSpike": { "$value": "{color.steel.800}", "$description": "Pressed Jet label on terracotta CTAs" }
    },
    "dark": {
      "$type": "color",
      "bgPage": { "$value": "{color.steel.800}" },
      "bgSurface": { "$value": "{color.steel.700}" },
      "bgElevated": { "$value": "{color.steel.600}" },
      "bgInput": { "$value": "rgba(255,255,255,0.045)" },
      "bgTrack": { "$value": "rgba(255,255,255,0.09)" },
      "fgPrimary": { "$value": "{color.linen.100}" },
      "fgBody": { "$value": "{color.steel.200}" },
      "fgCaption": { "$value": "{color.steel.300}" },
      "fgMuted": { "$value": "{color.steel.400}" },
      "ruleHairline": { "$value": "rgba(255,255,255,0.10)" },
      "ruleHairlineStrong": { "$value": "rgba(255,255,255,0.20)" },
      "accent": { "$value": "{color.terra.500}" },
      "accentText": { "$value": "{color.terra.300}" },
      "onSpike": { "$value": "{color.steel.800}" },
      "semanticWashOverride": {
        "$description": "In dark, each family's wash (50) goes deep and its on-light text (700) goes light. Solids unchanged.",
        "success50": { "$value": "#16271C" }, "success700": { "$value": "#8FD6A2" },
        "warning50": { "$value": "#2A2410" }, "warning700": { "$value": "#E9C879" },
        "error50": { "$value": "#2C1614" }, "error700": { "$value": "#F0A39C" },
        "info50": { "$value": "#13202B" }, "info700": { "$value": "#93C4E2" }
      }
    }
  },

  "font": {
    "$type": "fontFamily",
    "sans": { "$value": ["Montserrat", "system-ui", "sans-serif"], "$description": "signage voice" },
    "body": { "$value": ["Karla", "system-ui", "sans-serif"], "$description": "reading voice" }
  },
  "type": {
    "$description": "size / lineHeight / letterSpacing per role. Display+Headline uppercase Montserrat 900; Title 800; body Karla 400.",
    "display":  { "size": { "$value": "clamp(120px,18vw,296px)" }, "lineHeight": { "$value": 0.82 }, "tracking": { "$value": "-0.015em" } },
    "headline": { "size": { "$value": "clamp(64px,8vw,108px)" }, "lineHeight": { "$value": 0.88 }, "tracking": { "$value": "-0.012em" } },
    "title":    { "size": { "$value": "34px" }, "lineHeight": { "$value": 1.1 }, "tracking": { "$value": "-0.01em" } },
    "lede":     { "size": { "$value": "24px" }, "lineHeight": { "$value": 1.5 } },
    "body":     { "size": { "$value": "17px" }, "lineHeight": { "$value": 1.6 } },
    "label":    { "size": { "$value": "11px" }, "weight": { "$value": 600 }, "tracking": { "$value": "0.16em" }, "case": { "$value": "uppercase" } },
    "kicker":   { "size": { "$value": "12px" }, "weight": { "$value": 700 }, "tracking": { "$value": "0.22em" }, "case": { "$value": "uppercase" } },
    "button":   { "weight": { "$value": 800 }, "tracking": { "$value": "0.06em" }, "case": { "$value": "uppercase" } }
  },

  "space": {
    "$type": "dimension", "$description": "strict 8-grid",
    "1": { "$value": "8px" }, "2": { "$value": "16px" }, "3": { "$value": "24px" }, "4": { "$value": "32px" },
    "5": { "$value": "40px" }, "6": { "$value": "48px" }, "7": { "$value": "56px" }, "8": { "$value": "64px" },
    "10": { "$value": "80px" }, "12": { "$value": "96px" }, "14": { "$value": "112px" }, "16": { "$value": "128px" }
  },
  "radius": {
    "$type": "dimension",
    "xs": { "$value": "4px", "$description": "badges" }, "sm": { "$value": "6px", "$description": "crisp data panels" },
    "md": { "$value": "10px" }, "lg": { "$value": "14px", "$description": "buttons + text fields" },
    "card": { "$value": "16px", "$description": "soft in-app card" }, "xl": { "$value": "18px" }, "xxl": { "$value": "24px", "$description": "bottom sheet" }, "pill": { "$value": "999px" }
  },
  "elevation": {
    "$type": "shadow",
    "heroLift": { "$value": "0 2px 6px rgba(0,0,0,0.08), 0 12px 40px rgba(0,0,0,0.08)" },
    "cardLift": { "$value": "0 8px 22px rgba(19,34,44,0.08)", "$description": "interactive .sq-card hover; dark = 0 10px 26px rgba(0,0,0,0.5)" }
  },
  "motion": {
    "easeOut": { "$value": "cubic-bezier(0.25,1,0.5,1)", "$description": "ease-out-quart — default" },
    "easeQuint": { "$value": "cubic-bezier(0.22,1,0.36,1)" },
    "durFast": { "$value": "180ms", "$description": "hover/focus" },
    "durStandard": { "$value": "320ms", "$description": "surface/modal" }
  }
}
